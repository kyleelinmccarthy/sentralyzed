# Database (Neon — use `vercel env pull` to sync)
DATABASE_URL=

# API (used by standalone API server in local dev)
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Frontend API URL
# Local dev: http://localhost:3001 (separate API server)
# Production: /api (same-origin, served by Next.js catch-all route)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth
SESSION_SECRET=change-me-to-a-random-64-char-string
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Encryption (for file storage)
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# Cookie domain (optional — only needed if API is on a different subdomain)
COOKIE_DOMAIN=

# WebSocket (set to true for local dev to co-host WS with API)
ENABLE_WS=true

# GitHub Integration (Phase 3)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
