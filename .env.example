# Database (PostgreSQL — local via docker-compose.dev.yml, production via Railway Postgres)
DATABASE_URL=postgresql://sentral:devpassword123@localhost:5433/sentral_dev

# API (used by standalone API server in local dev)
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Frontend API URL
# Local dev: http://localhost:3001 (separate API server)
# Production: same-origin API subdomain (e.g., https://api.sentral.solvretech.com)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Frontend public app URL (used by auth-client during SSR and by Better Auth baseURL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WebSocket URL consumed by the browser client
# Local dev: ws://localhost:3002 (separate WS port)
# Production: wss://<api-subdomain> (shared with HTTP on single Railway port)
NEXT_PUBLIC_WS_URL=ws://localhost:3002

# Auth
SESSION_SECRET=change-me-to-a-random-64-char-string
BETTER_AUTH_SECRET=change-me-to-a-random-64-char-string
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Encryption (for file storage)
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# Cookie domain (optional — set when API and Web are on different subdomains sharing a parent)
COOKIE_DOMAIN=

# WebSocket
# ENABLE_WS=false disables the WebSocket server entirely.
# WS_PORT selects a dedicated port for local dev. Omit WS_PORT in production so WS
# attaches to the HTTP server on PORT (required for Railway single-port hosting).
ENABLE_WS=true
WS_PORT=3002

# GitHub Integration (Phase 3)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
