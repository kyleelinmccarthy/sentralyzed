{
  "name": "@sentral/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./app": {
      "types": "./src/app.ts",
      "default": "./dist/app.js"
    },
    "./auth": {
      "types": "./src/lib/better-auth.d.ts",
      "default": "./dist/lib/better-auth.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed/index.ts"
  },
  "dependencies": {
    "@better-auth/utils": "^0.4.0",
    "@better-fetch/fetch": "^1.1.21",
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.7.6",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@sentral/shared": "*",
    "better-auth": "^1.6.2",
    "better-call": "^2.0.3",
    "defu": "^6.1.7",
    "drizzle-orm": "^0.45.2",
    "helmet": "^8.1.0",
    "hono": "^4.7.0",
    "jose": "^6.2.2",
    "kysely": "^0.28.16",
    "nanostores": "^1.2.0",
    "postgres": "^3.4.5",
    "ws": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@sentral/config": "*",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
